{
  "name": "justuuid",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:migrate": "wrangler d1 migrations apply justuuid-db",
    "db:migrate:local": "wrangler d1 migrations apply justuuid-db --local",
    "deploy": "npm run build && wrangler pages deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@sveltejs/adapter-cloudflare": "^4.8.0",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "wrangler": "^3.101.0"
  }
}
